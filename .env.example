INSFORGE_URL=http://localhost:7130
INSFORGE_API_KEY=replace-with-server-admin-key
INSFORGE_LEARN_REGION=hamburg
PUBLIC_INSFORGE_URL=http://localhost:7130
PUBLIC_INSFORGE_ANON_KEY=replace-with-public-anon-key

# Used by the official @insforge/mcp server. Keep these in sync with the values above.
API_BASE_URL=http://localhost:7130
API_KEY=replace-with-server-admin-key

# Set to true in CI/production if a configured Insforge DB must fail loudly.
INSFORGE_STRICT=false
