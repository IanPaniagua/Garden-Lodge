---
// Minimal outline icon set (~1.75px stroke, single color) — brand kit §12.
interface Props {
  name:
    | "sun"
    | "droplet"
    | "sprout"
    | "calendar"
    | "wrench"
    | "bug"
    | "bolt"
    | "leaf"
    | "ruler"
    | "shovel"
    | "tag"
    | "arrow-right"
    | "whatsapp"
    | "mail"
    | "youtube"
    | "users";
